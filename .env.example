# ============================================================
# CNFuturesTrade Configuration
# ============================================================
# Trading mode: "test" (TTS simulation) or "live" (real CTP)
# Default is "test" — safe for offline development.
# ============================================================
TRADE_MODE=test

# ---------- CTP (实盘, TRADE_MODE=live) ----------
CTP_USER_ID=
CTP_PASSWORD=
CTP_BROKER_ID=
CTP_TD_FRONT=
CTP_MD_FRONT=
CTP_APP_ID=
CTP_AUTH_CODE=

# ---------- TTS (模拟, TRADE_MODE=test) ----------
# BrokerID=9999 是 TTS 环境的标准值, AppID/AuthCode 留空
# 7x24 环境(7×24可用): TD=tcp://trading.openctp.cn:30001 MD=tcp://trading.openctp.cn:30011
# 仿真环境(交易日日盘): TD=tcp://trading.openctp.cn:30002 (无行情)
TTS_USER_ID=
TTS_PASSWORD=
TTS_BROKER_ID=9999
TTS_TD_FRONT=tcp://trading.openctp.cn:30001
TTS_MD_FRONT=tcp://trading.openctp.cn:30011
TTS_APP_ID=
TTS_AUTH_CODE=