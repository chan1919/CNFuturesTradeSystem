# ============================================================
# CNFuturesTrade Configuration
# ============================================================
# TRADE_MODE=test  -> TTS simulation backend (default)
# TRADE_MODE=live  -> real CTP backend
# Backend selection is handled by:
#   - src/common/config.py
#   - src/gateway/_ctp_backend.py
# ============================================================
TRADE_MODE=test

# ---------- CTP (TRADE_MODE=live) ----------
CTP_USER_ID=
CTP_PASSWORD=
CTP_BROKER_ID=
CTP_TD_FRONT=
CTP_MD_FRONT=
CTP_APP_ID=
CTP_AUTH_CODE=

# ---------- TTS (TRADE_MODE=test) ----------
# TTS is the primary development and integration backend.
# BrokerID=9999 is the standard TTS broker id.
# Common 7x24 environment:
#   TD=tcp://trading.openctp.cn:30001
#   MD=tcp://trading.openctp.cn:30011
TTS_USER_ID=
TTS_PASSWORD=
TTS_BROKER_ID=9999
TTS_TD_FRONT=tcp://trading.openctp.cn:30001
TTS_MD_FRONT=tcp://trading.openctp.cn:30011
TTS_APP_ID=
TTS_AUTH_CODE=

# ============================================================
# Messenger Layer — IM Platform Credentials
# ============================================================
# Only configure the platforms you intend to use.
# For local development, start with Telegram (simplest setup).

# ---------- Feishu (飞书) ----------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFY_TOKEN=
FEISHU_NOTIFY_CHATS=

# ---------- DingTalk (钉钉) ----------
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_NOTIFY_CHATS=

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHATS=
